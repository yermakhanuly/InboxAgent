# === Telegram ===
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_USER_ID=your_numeric_telegram_user_id

# === OpenAI ===
OPENAI_API_KEY=sk-...

# === Google OAuth2 ===
# Create at console.cloud.google.com — "Desktop app" type
# Required scopes: gmail.readonly, calendar.readonly
GOOGLE_CLIENT_ID=....apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REDIRECT_URI=http://localhost:8080/callback/google

# === Microsoft OAuth2 ===
# Create at portal.azure.com — App Registration
# Required scopes: Mail.Read, Calendars.Read, offline_access
MICROSOFT_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MICROSOFT_CLIENT_SECRET=your_client_secret_here
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:8080/callback/microsoft

# === Security ===
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=your_fernet_key_here

# === Database ===
DATABASE_PATH=/data/inboxagent.db

# === Scheduler ===
DEFAULT_TIMEZONE=Europe/London
DIGEST_HOUR=8
DIGEST_MINUTE=0

# === Digest Settings ===
MAX_EMAILS_PER_PROVIDER=20
EMAIL_LOOKBACK_HOURS=24

# === OAuth Callback Server ===
OAUTH_CALLBACK_HOST=localhost
OAUTH_CALLBACK_PORT=8080
OAUTH_STATE_TIMEOUT_SECONDS=300
